# HealthPath Agent — 环境变量配置模板
# 复制本文件为 .env 并填写实际值（.env 已在 .gitignore 中，不会被提交）

# ────────────────────────────────────────────────────────────────────
# AutoClaw 工作区路径（通常不需要修改）
# ────────────────────────────────────────────────────────────────────
AUTOCLAW_WORKSPACE=C:\Users\Administrator\.openclaw-autoclaw

# ────────────────────────────────────────────────────────────────────
# 百度地图 API Key（可选）
# 仅在直接调用百度地图 API 时需要；通过 AutoClaw MCP 调用时此项无效
# 申请地址：https://lbsyun.baidu.com/
# ────────────────────────────────────────────────────────────────────
# BAIDU_MAP_API_KEY=你的Key

# ────────────────────────────────────────────────────────────────────
# 输出目录（可选，默认为项目根目录下的 output/）
# ────────────────────────────────────────────────────────────────────
# OUTPUT_DIR=./output
