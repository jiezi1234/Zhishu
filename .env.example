# HealthPath Agent 环境变量配置

# 百度地图 Agent Plan Token（可选）
# 有此 Token 时启用：全国医院搜索 + 精确路线规划
# 无此 Token 时降级：仅北京本地 CSV 数据 + 区划估算距离
# 申请地址：https://lbs.baidu.com/apiconsole/agentplan
BAIDU_MAP_AUTH_TOKEN=

# DeepSeek API Key（v1.0 意图解析 skill 使用）
# v2.0 主流程不依赖此 Key，但 tests/test_integration.py 需要
# 申请地址：https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# 输出目录（可选，默认为项目根目录下的 output/）
# 生成的 PDF 行程单将保存在此目录
# OUTPUT_DIR=output

# AutoClaw 工作区路径（可选，默认为 C:\Users\Administrator\.openclaw-autoclaw）
# AUTOCLAW_WORKSPACE=C:\Users\Administrator\.openclaw-autoclaw

# ── 语义模型配置 ──────────────────────────────────────────────────
# HuggingFace 镜像源（国内用户无需修改，代码已默认设为 hf-mirror.com）
# 如需切换其他镜像或使用官方源，取消注释：
# HF_ENDPOINT=https://hf-mirror.com

# 语义模型名称（可选，默认 BAAI/bge-small-zh-v1.5，约 90MB）
# 追求更高精度可换 BAAI/bge-base-zh-v1.5（约 400MB）
# ST_MODEL=BAAI/bge-small-zh-v1.5
