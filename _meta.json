{
  "name": "healthpath-agent",
  "version": "1.0.0",
  "description": "智能医疗就诊路线规划系统，帮助用户找到最合适的医院和医生",
  "author": "HealthPath Team",
  "license": "MIT",
  "entry_point": "main_skill.execute",
  "info_endpoint": "main_skill.get_info",
  "capabilities": [
    "自然语言理解",
    "医院号源搜索",
    "多维度评分排序",
    "PDF文档生成"
  ],
  "input_schema": {
    "type": "object",
    "properties": {
      "user_input": {
        "type": "string",
        "description": "用户的自然语言输入，描述医疗就诊需求"
      },
      "output_format": {
        "type": "string",
        "enum": ["pdf", "large_font_pdf"],
        "default": "large_font_pdf",
        "description": "输出格式：pdf (标准版) 或 large_font_pdf (大字版)"
      }
    },
    "required": ["user_input"]
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "status": {
        "type": "string",
        "enum": ["success", "error", "no_results"],
        "description": "执行状态"
      },
      "steps": {
        "type": "object",
        "description": "各个步骤的执行结果"
      },
      "final_output": {
        "type": "object",
        "description": "最终输出（PDF文件路径等）"
      },
      "error": {
        "type": "string",
        "description": "错误信息（如果有）"
      }
    }
  },
  "dependencies": [
    "skill_1_intent",
    "skill_2_crawl",
    "skill_3_decision",
    "skill_4_output"
  ],
  "tags": [
    "medical",
    "healthcare",
    "appointment",
    "hospital",
    "elderly-friendly"
  ],
  "performance": {
    "average_response_time_ms": 5000,
    "max_response_time_ms": 30000,
    "cache_enabled": true,
    "cache_ttl_hours": 24
  }
}
